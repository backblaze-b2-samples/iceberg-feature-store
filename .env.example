# Backblaze B2 (required) — the only credentials this app needs.
B2_ENDPOINT=your_b2_endpoint
B2_REGION=your_b2_region
B2_APPLICATION_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name

# Example of what filled-in values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_APPLICATION_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=<your-application-key-shown-once-at-key-creation>
# B2_BUCKET_NAME=my-feature-store-bucket

# Optional: a public base URL if your bucket is served publicly (used to build
# direct object URLs in addition to short-lived presigned downloads).
# B2_PUBLIC_URL=https://my-feature-store-bucket.s3.us-west-004.backblazeb2.com
